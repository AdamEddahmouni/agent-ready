{
  "name": "@adameddahmouni/agent-ready",
  "version": "0.5.0",
  "description": "The standard for agent-instruction files. Define commands, paths, and verification once in agent-ready.yaml — validate, enforce, generate AGENTS.md/CLAUDE.md/.cursorrules, and verify the work. Zero API keys, zero cost.",
  "keywords": [
    "agent-ready",
    "ai-agents",
    "specification",
    "cli",
    "repository-contract",
    "agents-md",
    "claude-md",
    "cursorrules",
    "copilot-instructions",
    "gemini-md",
    "contract",
    "verification",
    "yaml",
    "developer-tools"
  ],
  "homepage": "https://github.com/AdamEddahmouni/agent-ready#readme",
  "bugs": {
    "url": "https://github.com/AdamEddahmouni/agent-ready/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AdamEddahmouni/agent-ready.git"
  },
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "bin": {
    "agent-ready": "dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": "./schemas/v1/agent-ready.schema.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "schemas",
    "LICENSE",
    "README.md",
    "compatibility"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.build.json",
    "clean": "node scripts/clean-dist.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:action-pins": "node scripts/check-action-pins.mjs",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:package": "pnpm build && node scripts/package-smoke.mjs",
    "test:watch": "vitest",
    "cli": "tsx src/cli/index.ts",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "commander": "^13.1.0",
    "semver": "^7.6.3",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/semver": "^7.5.8",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
